@using BoneLog.Tools
@inject SiteConfig Config

<div class="post-preview @(ImageOnRight ? "post-preview--image-right" : "")">
    @if (ShowImage && !string.IsNullOrWhiteSpace(ThumbnailUrl))
    {
        <div class="post-preview__media">
            <img src="@ThumbnailUrl" alt="Post thumbnail" @onerror="OnImageError"
                 class="post-preview__image" />
        </div>
    }

    <div class="post-preview__body">
        <div>
            <a href="@PostHref" class="post-preview__title-link">
                <h2 class="post-preview__title">
                    @Title
                </h2>
                <p class="post-preview__description">
                    @Description
                </p>
            </a>
        </div>
        <div class="post-preview__meta">
            @if (!string.IsNullOrWhiteSpace(Category) || ExtraLanguages?.Length > 0 || Tags?.Length > 0)
            {
                <div class="post-meta-groups">
                    @if (!string.IsNullOrWhiteSpace(Category) || ExtraLanguages?.Length > 0)
                    {
                        <div class="post-meta-primary">
                            @if (!string.IsNullOrWhiteSpace(Category))
                            {
                                <Category Name="@Category" />
                            }
                            @if (ExtraLanguages?.Length > 0)
                            {
                                @foreach (var language in ExtraLanguages)
                                {
                                    <span class="language" lang="@language">
                                        <span class="language__code">@language.ToUpperInvariant()</span>
                                    </span>
                                }
                            }
                        </div>
                    }
                    @if (Tags?.Length > 0)
                    {
                        <div class="post-meta-tags">
                            @foreach (var tag in Tags)
                            {
                                <Tag TagName="@tag" />
                            }
                        </div>
                    }
                </div>
            }
            @if (PublishDate is not null)
            {
                <span class="post-preview__date">
                    @PublishDate.Value.ToString("MMM dd, yyyy")
                </span>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public string Id { get; set; } = "";
    [Parameter] public string Slug { get; set; } = "";
    [Parameter] public string LinkLanguage { get; set; } = PathExtensions.DefaultLanguage;
    [Parameter] public string[]? ExtraLanguages { get; set; }
    [Parameter] public string? ThumbnailUrl { get; set; }
    [Parameter] public string? Category { get; set; }
    [Parameter] public string[]? Tags { get; set; }
    [Parameter] public DateTime? PublishDate { get; set; }
    [Parameter] public bool ImageOnRight { get; set; } = true;

    private bool ShowImage = true;

    private string PostHref => PostIndexHelpers.ToPostUrl(Id, Slug, LinkLanguage);

    private void OnImageError()
    {
        ShowImage = false;
        StateHasChanged();
    }
}
