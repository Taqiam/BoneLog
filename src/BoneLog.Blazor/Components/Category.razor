@if (!string.IsNullOrEmpty(Name))
{
    var segments = Name.Split(PostPathHelper.CategorySeparator, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

    <SearchQueryLink Query="@($"Cat:{Name}")">
        <span class="category">
            @for (var i = 0; i < segments.Length; i++)
            {
                if (i > 0)
                {
                    <span class="category__sep" aria-hidden="true">/</span>
                }
                <span class="category__segment">@segments[i]</span>
            }
        </span>
    </SearchQueryLink>
}

@code {
    [Parameter]
    public string? Name { get; set; }
}