@inject IBlogContentProvider PostReader

<aside class="tag-box" aria-label="Tags">
    <h2 class="tag-box__title">Tags</h2>

    @if (isLoading)
    {
        <p class="tag-box__status">Loading…</p>
    }
    else if (tags.Length == 0)
    {
        <p class="tag-box__status">No tags yet.</p>
    }
    else
    {
        <nav class="tag-box__nav">
            <div class="tag-box__cloud">
                @foreach (var entry in tags)
                {
                    var isActive = IsTagSelected(entry.Tag);
                    <SearchQueryLink Query="@($"Tag:{entry.Tag}")"
                                     Class="@($"tag-box__chip{(isActive ? " tag-box__chip--active" : "")}")">
                        <span class="tag-box__label">@entry.Tag</span>
                        <span class="tag-box__count">@entry.Count</span>
                    </SearchQueryLink>
                }
            </div>
        </nav>
    }
</aside>

@code {
    [Parameter]
    public string? SelectedTag { get; set; }

    private bool isLoading = true;
    private TagEntry[] tags = [];

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        var posts = await PostReader.GetIndex();
        var tagCounts = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        foreach (var post in posts)
        {
            if (post.Tags is not { Length: > 0 })
                continue;

            foreach (var tag in post.Tags.Distinct(StringComparer.OrdinalIgnoreCase))
            {
                tagCounts.TryGetValue(tag, out var count);
                tagCounts[tag] = count + 1;
            }
        }

        tags = tagCounts
            .Select(kv => new TagEntry(kv.Key, kv.Value))
            .OrderBy(e => e.Tag, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        isLoading = false;
    }

    private bool IsTagSelected(string tag) =>
        !string.IsNullOrEmpty(SelectedTag)
        && SelectedTag.Equals(tag, StringComparison.OrdinalIgnoreCase);

    private sealed record TagEntry(string Tag, int Count);
}
