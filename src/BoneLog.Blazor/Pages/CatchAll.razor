@page "/{**slug}"
@inject IBlogContentProvider Reader

<div class="page-container">

    @if (isLoading)
    {
        <Loading />
    }
    else if (htmlContent is null)
    {
        <NotFound />
    }
    else
    {
        <MarkdownContent Content="@htmlContent"
                         ContentPath="@slug"
                         ContentKind="page"
                         PostUrlMap="@postUrlMap" />
    }

</div>

@code {

    [Parameter] public string slug { get; set; } = null!;

    private string? htmlContent = null;
    private bool isLoading = true;
    private Dictionary<string, string>? postUrlMap;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        var index = await Reader.GetIndex();
        postUrlMap = index.BuildPostUrlMap();
        htmlContent = await Reader.GetContent(slug);
        isLoading = false;
    }
}
