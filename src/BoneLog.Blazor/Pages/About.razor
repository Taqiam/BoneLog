@page "/about"
@inject HttpClient httpClient
@inject IJSRuntime JS
@inject SiteConfig Config

<PageTitle>About Me</PageTitle>

<div class="page-container page-container--centered">

    <div class="about-profile">
            @if (!string.IsNullOrWhiteSpace(Config.AboutMe.Avatar))
            {
                <div class="about-avatar-wrap">
                    <img src="@Config.AboutMe.Avatar" alt="Avatar" class="about-avatar" />
                </div>
            }

            <h1 class="about-name">@Config.AboutMe.Name</h1>
            <div class="about-divider"></div>
            <p class="about-headline">@Config.AboutMe.Headline</p>
        </div>

        @if (string.IsNullOrEmpty(htmlContent))
        {
            <div class="markdown-content markdown-content--left">
                @((MarkupString)htmlContent)
            </div>
        }
</div>

@code {
    private string htmlContent = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var response = await httpClient.GetAsync(Config.AboutMe.ContentUrl);
        if (!response.IsSuccessStatusCode)
            return;

        string markdown = await response.Content.ReadAsStringAsync();
        htmlContent = markdown.RemoveYamlHeader().MarkdownToHtml();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (htmlContent != null)
        {
            await JS.InvokeVoidAsync("Prism.highlightAll");
        }
    }
}
