@page "/about"
@inject IBlogContentProvider PostReader

<PageTitle>About Me</PageTitle>

<div class="page-container page-container--centered">

    @if (about is not null)
    {
        <div class="about-profile">
            @if (!string.IsNullOrWhiteSpace(about.Avatar))
            {
                <div class="about-avatar-wrap">
                    <img src="@about.Avatar" alt="Avatar" class="about-avatar" />
                </div>
            }

            <h1 class="about-name">@about.Name</h1>
            <div class="about-divider"></div>
            @if (!string.IsNullOrWhiteSpace(about.Headline))
            {
                <p class="about-headline">@about.Headline</p>
            }
        </div>

        <MarkdownContent Content="@about.Content"
                         ContentPath="AboutMe.md"
                         ContentKind="page"
                         PostUrlMap="@postUrlMap"
                         AdditionalCssClass="markdown-content--left" />
    }
</div>

@code {
    private AboutMe? about;
    private Dictionary<string, string>? postUrlMap;

    protected override async Task OnInitializedAsync()
    {
        var index = await PostReader.GetIndex();
        postUrlMap = index.BuildPostUrlMap();
        about = await PostReader.GetAboutMe();
    }
}
