@page "/about"
@inject HttpClient httpClient
@inject IJSRuntime JS
@inject SiteConfig Config

<PageTitle>About Me</PageTitle>

<div class="max-w-3xl mx-auto px-4 py-8 text-center">

    @if (isLoading)
    {
        <Loading />
    }
    else
    {
        <div class="mb-6">
            @if (!string.IsNullOrWhiteSpace(Config.AboutMe.Avatar))
            {
                <div class="mx-auto w-32 h-32 rounded-full overflow-hidden border border-neutral-300 dark:border-white/20">
                    <img src="@Config.AboutMe.Avatar" alt="Avatar" class="w-full h-full object-cover" />
                </div>
            }

            <h1 class="mt-4 text-2xl font-bold text-inherit">@Config.AboutMe.Name</h1>
            <div class="border-t border-neutral-300 dark:border-white/20 my-4 w-1/2 mx-auto"></div>
            <p class="text-sm text-gray-600 dark:text-gray-300">@Config.AboutMe.Headline</p>
        </div>

        @if (string.IsNullOrEmpty(htmlContent))
        {
            <div class="prose dark:prose-invert max-w-none font-serif text-inherit text-left">
                @((MarkupString)htmlContent)
            </div>
        }
    }
</div>

@code {
    private string htmlContent = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var response = await httpClient.GetAsync(Config.AboutMe.ContentUrl);
        if (!response.IsSuccessStatusCode)
            return;

        string markdown = await response.Content.ReadAsStringAsync();
        htmlContent = markdown.RemoveYamlHeader().MarkdownToHtml();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (htmlContent != null)
        {
            await JS.InvokeVoidAsync("Prism.highlightAll");
        }
    }
}