@page "/posts/{Language}/{Id}/{Slug}"
@inject SiteConfig Config

<PageTitle>@((string)(post?.Title ?? "Post"))</PageTitle>

<div class="page-container">
    @if (isLoading)
    {
        <Loading />
    }

    else if (post is null)
    {
        <NotFound />
    }
    else
    {
        <h1 class="post-header">@post.Title</h1>
        <div class="post-meta">
            @if (!string.IsNullOrWhiteSpace(post.Category) || indexEntry?.Languages.Length > 1 || post.Tags?.Length > 0)
            {
                <div class="post-meta-groups">
                    @if (!string.IsNullOrWhiteSpace(post.Category) || indexEntry?.Languages.Length > 1)
                    {
                        <div class="post-meta-primary">
                            @if (!string.IsNullOrWhiteSpace(post.Category))
                            {
                                <Category Name="@post.Category" />
                            }
                            @if (indexEntry is not null && indexEntry.Languages.Length > 1)
                            {
                                <PostLanguageSwitcher Index="@indexEntry" CurrentLanguage="@Language" />
                            }
                        </div>
                    }
                    @if (post.Tags?.Length > 0)
                    {
                        <div class="post-meta-tags">
                            @foreach (var tag in post.Tags)
                            {
                                <Tag TagName="@tag" />
                            }
                        </div>
                    }
                </div>
            }
            @if (post.Date is not null)
            {
                <span class="post-meta__date">@post.Date.Value.ToString("MMM dd, yyyy")</span>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(post.Cover))
        {
            <div class="post-cover">
                <img src="@post.Cover" alt="Post image" class="post-cover__image" />
            </div>
        }
        <MarkdownContent Content="@post.Content"
                         ContentPath="@post.FilePath"
                         ContentKind="post"
                         PostUrlMap="@postUrlMap" />
    }
</div>

@code {
    [Inject] IBlogContentProvider Reader { get; set; } = default!;

    [Parameter] public string Language { get; set; } = "";
    [Parameter] public string Id { get; set; } = "";
    [Parameter] public string Slug { get; set; } = "";

    private bool isLoading = true;
    private Post? post;
    private PostIndex? indexEntry;
    private Dictionary<string, string>? postUrlMap;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(Id) || string.IsNullOrWhiteSpace(Language) || !Id.TryNormalizePostId(out var normalizedId))
        {
            post = null;
            indexEntry = null;
            isLoading = false;
            return;
        }

        isLoading = true;
        var index = await Reader.GetIndex();
        postUrlMap = index.BuildPostUrlMap();
        indexEntry = await Reader.GetPostIndexEntry(normalizedId);
        post = await Reader.GetPostByIdAndLanguage(normalizedId, Language);
        isLoading = false;
    }
}
